# MongoDB connection
MONGO_URI=mongodb://mongodb:27017/lyx

# MinIO object storage - CHANGE THESE IN PRODUCTION
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=lyxadmin
MINIO_SECRET_KEY=lyxsecret
MINIO_BUCKET=lyx-bundles

# JWT - CHANGE THIS IN PRODUCTION (use: openssl rand -base64 32)
JWT_SECRET=change-me-in-production

# CORS origin (use specific origin in production, e.g. https://admin.example.com)
CORS_ORIGIN=*

# Ports
ADMIN_API_PORT=4000
ADMIN_UI_PORT=4001
