# MongoDB Atlas connection string
# Get from: https://cloud.mongodb.com → Connect → Drivers
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/lyx

# AWS S3 bucket for MFE bundles
S3_BUCKET=lyx-bundles

# AWS region
AWS_REGION=us-west-2

# AWS credentials (from `lyx aws login` or IAM user)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# JWT secret (use: openssl rand -base64 32)
JWT_SECRET=change-me-in-production

# CORS origin (use specific origin in production)
CORS_ORIGIN=*
